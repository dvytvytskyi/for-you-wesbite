#!/usr/bin/expect -f
set timeout 10
set host "135.181.201.185"
set user "root"
set password "xTVvPEwrpaF4"

spawn ssh -o StrictHostKeyChecking=no $user@$host
expect "password:"
send "$password\r"
expect "#"
send "ls -F /\r"
expect "#"
send "ls -F /var/www\r"
expect "#"
send "ls -F /root\r"
expect "#"
# Check if there is an api directory
send "ls -F /root/api\r" 
expect "#"
send "exit\r"
expect eof
